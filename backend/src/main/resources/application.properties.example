spring.application.name=notemind-api

spring.datasource.url=jdbc:postgresql://localhost:5432/notemind_ai
spring.datasource.username=postgres
spring.datasource.password=Sukhmeet@918
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
